{
  "manifest_version": 3,
  "name": "Code Injector",
  "version": "1.0.0",
  "description": "Inject custom JS or CSS on specific URLs.",
  "icons": {
    "16": "icons/16px.png",
    "48": "icons/48px.png",
    "128": "icons/128px.png"
  },
  "action": {
    "default_title": "Code Injector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16px.png",
      "48": "icons/48px.png",
      "128": "icons/128px.png"
    }
  },
  "options_page": "rules.html",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}

